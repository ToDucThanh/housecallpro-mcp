{
  "name": "hcpro",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "hcpro": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build:darwin-arm64": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile ../dist/hcpro-darwin-arm64",
    "build:darwin-x64":   "bun build src/index.ts --compile --target=bun-darwin-x64   --outfile ../dist/hcpro-darwin-x64",
    "build:linux-x64":    "bun build src/index.ts --compile --target=bun-linux-x64    --outfile ../dist/hcpro-linux-x64",
    "build:linux-arm64":  "bun build src/index.ts --compile --target=bun-linux-arm64  --outfile ../dist/hcpro-linux-arm64"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "@inquirer/prompts": "^7.0.0",
    "open": "^10.0.0",
    "@modelcontextprotocol/sdk": "latest",
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
