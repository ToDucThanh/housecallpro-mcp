# Auth option 1: Company API Key (simpler, for single-company use)
HOUSECALL_API_KEY=your_api_key_here

# Auth option 2: OAuth 2.0 (for multi-company / partner apps)
HOUSECALL_CLIENT_ID=your_client_id_here
HOUSECALL_CLIENT_SECRET=your_client_secret_here
HOUSECALL_OAUTH_TOKEN=your_oauth_token_here

# Which auth method to use: "apikey" or "oauth"
HOUSECALL_AUTH_METHOD=apikey
